{
  "name": "@awecode/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "awecode": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "cross-env AWECODE_E2E_API_KEY=1 vitest run tests/e2e.test.ts",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@awecode/agent": "workspace:*",
    "@awecode/diff": "workspace:*",
    "@awecode/llm": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "@types/react": "^19.2.17",
    "ink": "^7.1.0",
    "ink-select-input": "^6.2.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "cross-env": "^10.1.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
