{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@awecode/gui/renderer/src/*": ["../gui/src/renderer/src/*"],
      "@awecode/gui/shared/*": ["../gui/src/shared/*"]
    }
  },
  "include": ["src/renderer/**/*", "tests/renderer/**/*"]
}
